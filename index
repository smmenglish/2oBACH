<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>English Resources | IES San Miguel de Meruelo</title>

  <style>
    :root {
      --bg: #1e1f29;
      --panel: #282a36;
      --panel2: #232530;

      --text: #e6e6e6;
      --muted: #a7a7b3;

      --accent: #8be9fd;
      --accent2: #bd93f9;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
    }

    body {
      background: radial-gradient(circle at top, #2a2d3e, var(--bg));
      color: var(--text);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    header {
      text-align: center;
      padding: 3rem 2rem 2rem;
    }

    h1 {
      font-size: 2rem;
      letter-spacing: 0.5px;
    }

    .subtitle {
      margin-top: 0.5rem;
      color: var(--muted);
      font-size: 0.95rem;
    }

    main {
      width: 100%;
      max-width: 850px;
      margin: 0 auto;
      padding: 1rem 2rem 3rem;
    }

    /* SECTION */
    .section {
      margin-bottom: 2rem;
    }

    .section-title {
      font-size: 1.2rem;
      margin-bottom: 0.8rem;
      padding-left: 0.6rem;
      border-left: 3px solid var(--accent);
      color: var(--accent);
    }

    /* ACCORDION */
    details {
      background: linear-gradient(145deg, var(--panel), var(--panel2));
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 12px;
      margin-bottom: 0.8rem;
      overflow: hidden;
      transition: 0.2s ease;
    }

    details:hover {
      border-color: var(--accent);
    }

    summary {
      cursor: pointer;
      padding: 1rem;
      font-weight: 600;
      color: var(--text);
      list-style: none;
      position: relative;
    }

    summary::after {
      content: "▾";
      position: absolute;
      right: 1rem;
      color: var(--accent);
      transition: 0.2s ease;
    }

    details[open] summary::after {
      transform: rotate(180deg);
    }

    /* LINKS INSIDE */
    .content {
      padding: 0 1rem 1rem 1rem;
    }

    .link {
      display: block;
      margin-top: 0.6rem;
      padding: 0.6rem 0.8rem;
      border-left: 2px solid var(--accent2);
      text-decoration: none;
      color: var(--text);
      border-radius: 6px;
      transition: 0.2s ease;
      background: rgba(0,0,0,0.15);
    }

    .link:hover {
      color: var(--accent);
      transform: translateX(4px);
    }

    .tag {
      font-size: 0.75rem;
      color: var(--muted);
      margin-top: 0.2rem;
    }

    footer {
      margin-top: auto;
      text-align: center;
      padding: 2rem;
      font-size: 0.8rem;
      color: var(--muted);
    }
  </style>
</head>

